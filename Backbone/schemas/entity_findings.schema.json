{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cyber-agent.local/schemas/entity_findings.schema.json",
  "title": "EntityFindings",
  "description": "Module → Orchestrator: response to an EntityQuery, or TI external enrichment result.",
  "type": "object",
  "required": [
    "contract_version",
    "query_id",
    "responding_module",
    "entity",
    "verdict",
    "justification",
    "evidence",
    "related_entities",
    "cost"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "type": "string", "const": "1.0" },
    "query_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "responding_module": {
      "type": "string",
      "enum": ["ram", "disk", "network", "ti"]
    },
    "entity": {
      "type": "object",
      "required": ["type", "value"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ip", "domain", "url",
            "hash_md5", "hash_sha1", "hash_sha256",
            "file_path", "image_name",
            "pid", "registry_key", "mutex", "user_sid"
          ]
        },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["CONFIRMED", "INCONCLUSIVE", "REJECTED", "NOT_FOUND", "NOT_APPLICABLE"]
    },
    "severity": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] }
      ]
    },
    "mitre": {
      "type": "array",
      "items": { "type": "string", "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$" },
      "default": []
    },
    "justification": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_file", "line", "content", "verbatim"],
        "additionalProperties": false,
        "properties": {
          "source_file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "content": { "type": "string" },
          "verbatim": { "type": "boolean" },
          "timestamp": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "format": "date-time" }
            ]
          }
        }
      }
    },
    "related_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value", "relationship"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ip", "domain", "url",
              "hash_md5", "hash_sha1", "hash_sha256",
              "file_path", "image_name",
              "pid", "registry_key", "mutex", "user_sid"
            ]
          },
          "value": { "type": "string", "minLength": 1 },
          "relationship": { "type": "string", "minLength": 1 }
        }
      }
    },
    "cost": {
      "type": "object",
      "required": ["llm_calls", "tokens_in", "tokens_out"],
      "additionalProperties": false,
      "properties": {
        "llm_calls": { "type": "integer", "minimum": 0 },
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "verdict": { "const": "CONFIRMED" } } },
      "then": {
        "properties": {
          "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] }
        },
        "required": ["severity"]
      },
      "else": {
        "properties": { "severity": { "type": "null" } }
      }
    }
  ]
}
