## 3. `collector_deep.json` -- full schema

JSON document the grep script slices by PID and by path. **Never read by an
LLM.** Designed for fast lookups, not for token efficiency.

```jsonc
{
  "schema_version": 1,
  "image": {
    "filename": "memory.raw",
    "sha256": "ab12f0e1c4d9a7b3e8d6c5f4a2b1c0d9e8f7a6b5c4d3e2f1a0b9c8d7e6f5a4b3",
    "size_bytes": 4294967296,
    "profile": "Win10x64_19041",
    "acquired": "2025-08-08T14:35:12Z"
  },

  "by_pid": {
    "4920": {
      "pid": 4920,
      "ppid": 6612,
      "name": "svchost.exe",
      "path": "C:\\Users\\Public\\svchost.exe",
      "user": "SYSTEM",
      "started": "2025-08-08T14:32:01Z",
      "exited":  null,
      "image_sha256": "...",
      "signed": false,
      "cmdline": "C:\\Users\\Public\\svchost.exe -k netsvcs",
      "privileges": ["SeDebugPrivilege", "SeImpersonatePrivilege", "SeTcbPrivilege"],
      "handles": [
        { "type": "File", "name": "\\Device\\NamedPipe\\lsass", "granted_access": "..." },
        { "type": "Mutant", "name": "winhelp_ctl" }
      ],
      "dlllist": [
        { "name": "ntdll.dll",   "base": "0x7ffe...", "path": "C:\\Windows\\System32\\ntdll.dll", "signed": true },
        { "name": "wininet.dll", "base": "0x7ffe...", "path": "C:\\Windows\\System32\\wininet.dll", "signed": true }
      ],
      "envars":    { "USERNAME": "SYSTEM", "TEMP": "C:\\Windows\\TEMP" },
      "threads":   8,
      "thread_ids":[4924, 4928, 4932, 4936, 4940, 4944, 4948, 4952],
      "network": [
        { "proto": "TCP", "local": "0.0.0.0:0", "remote": "185.220.101.5:443",
          "state": "ESTABLISHED", "created": "2025-08-08T14:32:08Z" }
      ],
      "malfind":   [],
      "flags":     ["wrong_path", "unsigned", "parent_is_lolbin", "lsass_handle", "external_conn"]
    }
  },

  "by_path": {
    "C:\\ProgramData\\winhelp.exe": {
      "filescan": [
        { "offset": "0xfa800c1d2210", "name": "\\ProgramData\\winhelp.exe", "size": 184320 }
      ],
      "registry_printkey": [
        { "hive": "SYSTEM",
          "key":  "ControlSet001\\Services\\WinHelpSvc",
          "value":"ImagePath",
          "type": "REG_EXPAND_SZ",
          "data": "C:\\ProgramData\\winhelp.exe" }
      ],
      "running_pids": [4920]
    }
  },

  "persistence": [
    {
      "id": "p1",
      "type": "service",
      "name": "WinHelpSvc",
      "binary": "C:\\ProgramData\\winhelp.exe",
      "start_type": "Auto",
      "linked_pid": 4920,
      "flags": ["unsigned_binary", "non_system_path"]
    }
  ],

  "process_tree": {
    "roots": [4],
    "edges": [[6088, 6240], [6240, 6612], [6612, 4920]],
    "orphans": [9999, 12108]
  }
}
```

Rules:
- `by_pid` keys are **strings** (JSON doesn't allow int keys; matches our
  TypeScript types in the frontend).
- Every per-PID record duplicates the basic fields (name, path, ppid)
  that also appear in the summary so the grep script doesn't need to
  cross-reference the text file. Disk is cheap.
- Lists are full and unfiltered -- this is the "everything we collected"
  store. Pruning happens in the summary, not here.
- `process_tree.edges` is `[parent_pid, child_pid]` pairs (not a nested
  structure) so it's flat and easy to use.

