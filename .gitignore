# ---------- DFIR runtime artifacts ----------
# Local case data should never be committed
cases/
*.mem
*.raw
*.vmem
*.dmp

# Per-module runtime output (extraction, collection, per-chunk LLM output, logs).
# The directories are kept (via .gitkeep) so the layout stays visible; contents are not.
Modules/RAM/INPUT/*
!Modules/RAM/INPUT/.gitkeep
Modules/RAM/RAM_Artifacts/*
!Modules/RAM/RAM_Artifacts/.gitkeep
Modules/RAM/ram-agentic-architecture/output/*
!Modules/RAM/ram-agentic-architecture/output/.gitkeep
Modules/RAM/ram-agentic-architecture/logs/*
!Modules/RAM/ram-agentic-architecture/logs/.gitkeep
Modules/Disk/Disk_Artifacts/*
!Modules/Disk/Disk_Artifacts/.gitkeep
Modules/Disk/disk-agentic-architecture/output/*
!Modules/Disk/disk-agentic-architecture/output/.gitkeep
Modules/Disk/disk-agentic-architecture/audit/*
!Modules/Disk/disk-agentic-architecture/audit/.gitkeep

# Disk image-mounter scratch ($MFT extraction)
INPUT_DISK/

# Orchestrator run output + test-run output (regenerated by the test suite)
Backbone/output/
Backbone/tests/test-data/output/

# ---------- Audit output ----------
# Runtime audit trees are never committed; only the documentation README is.
auditing/*
!auditing/README.md
